{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "housecheck-api.vercel.app" }],
      "destination": "https://housecheck.it.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "housecheck-api.vercel.app" }],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
